<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Dashboard</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
<div class="container">
  <h2>📈 Seus Gastos</h2>
  <div id="score"></div>
  <div id="total"></div>
  <div id="essencial"></div>
  <div id="complementar"></div>
  <div id="superfluo"></div>
  <div id="insights"></div>
  <button onclick="window.location.href='index.html'">← Voltar</button>
</div>

<script src="script.js"></script>
<script>
  const API = "https://script.google.com/macros/s/SEU_ID_AQUI/exec";

  async function carregarDashboard() {
    document.getElementById("total").textContent = "Carregando...";
    try {
      const [relRes, insRes] = await Promise.all([
        fetch(API + "?acao=relatorio"),
        fetch(API + "?acao=insights")
      ]);
      const rel = await relRes.json();
      const ins = await insRes.json();

      document.getElementById("score").textContent =
        "🎯 Score: " + rel.score + "/100";
      document.getElementById("total").textContent =
        "💰 Total do mês: R$ " + (rel.totalMesAtual || 0).toFixed(2);
      document.getElementById("essencial").textContent =
        "🟢 Essencial: R$ " + (rel.grupos?.Essencial || 0).toFixed(2);
      document.getElementById("complementar").textContent =
        "🟡 Complementar: R$ " + (rel.grupos?.Complementar || 0).toFixed(2);
      document.getElementById("superfluo").textContent =
        "🔴 Supérfluo: R$ " + (rel.grupos?.Superfluo || 0).toFixed(2);

      const insDiv = document.getElementById("insights");
      insDiv.innerHTML = (ins.insights || [])
        .map(i => `<p>${i.icone} ${i.mensagem}</p>`)
        .join("");
    } catch (e) {
      document.getElementById("total").textContent = "Erro ao carregar: " + e.message;
    }
  }

  carregarDashboard();
</script>
</body>
</html>
